import { useState, useEffect } from 'react'
import { ethers } from 'ethers'
import DOMPurify from 'dompurify'
import './App.css'
// HIGH-04 FIX: RPC Fallback
const RPC_ENDPOINTS = [
  "https://ethereum-sepolia-rpc.publicnode.com",
  "https://sepolia.drpc.org",
  "https://rpc.sepolia.org",
  "https://rpc2.sepolia.org"
]

async function getWorkingProvider() {
  for (const url of RPC_ENDPOINTS) {
    try {
      const p = new ethers.JsonRpcProvider(url)
      await p.getBlockNumber()
      console.log("✅ Connected to:", url)
      return p
    } catch (e) {
      console.warn("❌ RPC failed:", url)
      continue
    }
  }
  throw new Error("All RPC endpoints down")
}

const BOUNTY_ESCROW = "0x[paste_address_dari_deploy]"
const VERIFIER_ADDRESS = import.meta.env.VITE_VERIFIER_ADDRESS

// ABI with new getters
const ABI = [
  "function createBounty(uint256 deadlineHours, uint8 minSeverity, uint256 claimTimeout) payable returns (uint256)",
  "function getBounty(uint256 id) view returns (tuple(address company, uint256 reward, uint256 deadline, uint256 claimTimeout, uint256 bountyId, uint8 minSeverity, uint8 state, address researcher, bytes32 commitment))",
  "function companyAccept(uint256 bountyId)",
  "function companyReject(uint256 bountyId)",
  "function refundExpired(uint256 bountyId)",
  "function getBountyCount() view returns (uint256)",
  "function getActiveBounties() view returns (uint256[])",
  "function paused() view returns (bool)"
]

// HIGH-04 FIX: RPC Fallback
const RPC_ENDPOINTS = [
  "https://ethereum-sepolia-rpc.publicnode.com",
  "https://sepolia.drpc.org",
  "https://rpc.sepolia.org",
  "https://rpc2.sepolia.org"
]

// MED-04 FIX: Debug wrapper (only logs in dev)
const DEBUG = import.meta.env.DEV
function debug(...args) {
  if (DEBUG) console.log(...args)
}

async function getWorkingProvider() {
  for (const url of RPC_ENDPOINTS) {
    try {
      const p = new ethers.JsonRpcProvider(url)
      await p.getBlockNumber()
      debug("✅ Connected to RPC:", url)
      return p
    } catch (e) {
      debug("❌ RPC failed:", url)
      continue
    }
  }
  throw new Error("All RPC endpoints are down")
}

function App() {
  const [provider, setProvider] = useState(null)
  const [wallet, setWallet] = useState(null)
  const [bounties, setBounties] = useState([])
  const [tab, setTab] = useState('bounties')
  const [loading, setLoading] = useState(false)
  const [refreshing, setRefreshing] = useState(false)
  const [msg, setMsg] = useState({ text: '', type: '' })
  const [txHash, setTxHash] = useState('') // MED-03 FIX
  
  // Form states
  const [hours, setHours] = useState('24')
  const [reward, setReward] = useState('0.01')
  const [minSev, setMinSev] = useState('5')
  const [claimTimeout, setClaimTimeout] = useState('7')
  
  // MED-01 FIX: Pagination
  const [page, setPage] = useState(0)
  const [totalBounties, setTotalBounties] = useState(0)
  const BOUNTIES_PER_PAGE = 20
  
  useEffect(() => {
    initProvider()
  }, [])
  
  useEffect(() => {
    if (provider) {
      loadBounties()
    }
  }, [provider, page])
  
  async function initProvider() {
    try {
      const p = await getWorkingProvider()
      setProvider(p)
    } catch (e) {
      showMsg("Failed to connect to network", "error")
    }
  }
  
  async function loadBounties() {
    setRefreshing(true)
    try {
      const p = provider || await getWorkingProvider()
      const contract = new ethers.Contract(BOUNTY_ESCROW, ABI, p)
      
      const count = await contract.getBountyCount()
      setTotalBounties(Number(count))
      
      const list = []
      const start = page * BOUNTIES_PER_PAGE + 1
      const end = Math.min(start + BOUNTIES_PER_PAGE, Number(count) + 1)
      
      for (let i = start; i < end; i++) {
        try {
          const b = await contract.getBounty(i)
          if (b.company === ethers.ZeroAddress) break
          
          list.push({
            id: i,
            company: b.company,
            reward: b.reward,
            deadline: b.deadline,
            claimTimeout: b.claimTimeout,
            bountyId: b.bountyId,
            minSeverity: b.minSeverity,
            state: b.state,
            researcher: b.researcher,
            commitment: b.commitment
          })
        } catch (e) {
          debug("Error loading bounty", i, e)
          break
        }
      }
      
      setBounties(list)
    } catch (e) {
      showMsg("Error loading bounties: " + e.message, "error")
    }
    setRefreshing(false)
  }
  
  async function connectWallet() {
    if (typeof window.ethereum === 'undefined') {
      return showMsg("Install MetaMask!", "error")
    }
    
    try {
      const p = new ethers.BrowserProvider(window.ethereum)
      await window.ethereum.request({ method: 'eth_requestAccounts' })
      
      const signer = await p.getSigner()
      const addr = await signer.getAddress()
      
      setProvider(p)
      setWallet(addr)
      
      debug("Connected:", addr)
      showMsg("Wallet connected!", "success")
    } catch (e) {
      showMsg("Connection failed: " + e.message, "error")
    }
  }
  
  // MED-02 FIX: Input validation
  async function postBounty() {
    if (!wallet) return showMsg("Connect wallet first!", "error")
    
    // Validate inputs
    const hoursNum = Number(hours)
    const rewardNum = Number(reward)
    const minSevNum = Number(minSev)
    const timeoutNum = Number(claimTimeout)
    
    if (isNaN(hoursNum) || hoursNum <= 0 || hoursNum > 8760) {
      return showMsg("Deadline must be 1-8760 hours (max 1 year)", "error")
    }
    if (isNaN(rewardNum) || rewardNum < 0.001) {
      return showMsg("Minimum reward is 0.001 ETH", "error")
    }
    if (isNaN(minSevNum) || minSevNum < 1 || minSevNum > 10) {
      return showMsg("Severity must be 1-10", "error")
    }
    if (isNaN(timeoutNum) || timeoutNum < 1 || timeoutNum > 30) {
      return showMsg("Claim timeout must be 1-30 days", "error")
    }
    
    setLoading(true)
    setTxHash('')
    
    try {
      const signer = await provider.getSigner()
      const contract = new ethers.Contract(BOUNTY_ESCROW, ABI, signer)
      
      // MED-05 FIX: Check paused state
      const paused = await contract.paused()
      if (paused) {
        setLoading(false)
        return showMsg("Contract is paused", "error")
      }
      
      // MED-05 FIX: Get fresh nonce
      const nonce = await signer.getTransactionCount()
      
      const claimTimeoutSec = timeoutNum * 24 * 3600
      
      const tx = await contract.createBounty(
        hoursNum,
        minSevNum,
        claimTimeoutSec,
        { 
          value: ethers.parseEther(reward),
          nonce
        }
      )
      
      setTxHash(tx.hash)
      showMsg(`TX submitted: ${tx.hash.slice(0, 10)}...`, "info")
      
      await tx.wait()
      
      showMsg("Bounty posted successfully!", "success")
      loadBounties()
      setTab("bounties")
      
      // Reset form
      setHours('24')
      setReward('0.01')
      setMinSev('5')
      setClaimTimeout('7')
      
    } catch (e) {
      showMsg("Error: " + (e.reason || e.message), "error")
    } finally {
      setLoading(false)
    }
  }
  
  function showMsg(text, type) {
    setMsg({ text, type })
    setTimeout(() => setMsg({ text: '', type: '' }), 5000)
  }
  
  function formatAddr(addr) {
    return addr ? `${addr.slice(0, 6)}...${addr.slice(-4)}` : ''
  }
  
  function formatTime(timestamp) {
    const date = new Date(Number(timestamp) * 1000)
    return date.toLocaleString()
  }
  
  function getStateLabel(state) {
    const states = ['Active', 'Pending Review', 'Accepted', 'Rejected', 'Refunded']
    return states[state] || 'Unknown'
  }
  
  const totalPages = Math.ceil(totalBounties / BOUNTIES_PER_PAGE)
  
  return (
    <div className="app">
      <header>
        <h1>💀 zkBounty Platform</h1>
        <div className="stats">
          <span>Total Bounties: {totalBounties}</span>
          <span>Active: {bounties.filter(b => b.state === 0).length}</span>
        </div>
        {!wallet ? (
          <button onClick={connectWallet} className="btn-primary">
            Connect Wallet
          </button>
        ) : (
          <div className="wallet-info">
            Connected: {formatAddr(wallet)}
          </div>
        )}
      </header>
      
      {msg.text && (
        <div className={`message message-${msg.type}`}>
          {msg.text}
        </div>
      )}
      
      {txHash && (
        <div className="tx-link">
          <a 
            href={`https://sepolia.etherscan.io/tx/${txHash}`} 
            target="_blank" 
            rel="noopener noreferrer"
          >
            View TX on Etherscan →
          </a>
        </div>
      )}
      
      <nav className="tabs">
        <button 
          className={tab === 'bounties' ? 'active' : ''} 
          onClick={() => setTab('bounties')}
        >
          Browse Bounties
        </button>
        <button 
          className={tab === 'post' ? 'active' : ''} 
          onClick={() => setTab('post')}
          disabled={!wallet}
        >
          Post Bounty
        </button>
      </nav>
      
      <main>
        {tab === 'bounties' && (
          <div>
            <div className="bounties-header">
              <h2>Available Bounties</h2>
              <button onClick={loadBounties} disabled={refreshing}>
                {refreshing ? 'Refreshing...' : 'Refresh'}
              </button>
            </div>
            
            <div className="bounties-grid">
              {bounties.length === 0 ? (
                <p>No bounties found. Be the first to post one!</p>
              ) : (
                bounties.map(b => (
                  <div className="bounty-card" key={b.id}>
                    <h3>Bounty #{b.id}</h3>
                    <p><strong>Reward:</strong> {ethers.formatEther(b.reward)} ETH</p>
                    <p><strong>Min Severity:</strong> {b.minSeverity}/10</p>
                    <p><strong>Deadline:</strong> {formatTime(b.deadline)}</p>
                    <p><strong>Status:</strong> <span className={`state-${b.state}`}>{getStateLabel(b.state)}</span></p>
                    <p><strong>Company:</strong> {formatAddr(b.company)}</p>
                    {b.researcher !== ethers.ZeroAddress && (
                      <p><strong>Researcher:</strong> {formatAddr(b.researcher)}</p>
                    )}
                  </div>
                ))
              )}
            </div>
            
            {totalPages > 1 && (
              <div className="pagination">
                <button 
                  onClick={() => setPage(p => Math.max(0, p - 1))}
                  disabled={page === 0}
                >
                  Previous
                </button>
                <span>Page {page + 1} of {totalPages}</span>
                <button 
                  onClick={() => setPage(p => Math.min(totalPages - 1, p + 1))}
                  disabled={page >= totalPages - 1}
                >
                  Next
                </button>
              </div>
            )}
          </div>
        )}
        
        {tab === 'post' && (
          <div className="post-form">
            <h2>Post New Bounty</h2>
            
            <div className="form-group">
              <label>Deadline (hours, max 8760):</label>
              <input 
                type="number" 
                value={hours} 
                onChange={e => setHours(e.target.value)}
                min="1"
                max="8760"
              />
            </div>
            
            <div className="form-group">
              <label>Reward (ETH, min 0.001):</label>
              <input 
                type="number" 
                step="0.001"
                value={reward} 
                onChange={e => setReward(e.target.value)}
                min="0.001"
              />
            </div>
            
            <div className="form-group">
              <label>Minimum Severity (1-10):</label>
              <input 
                type="number" 
                value={minSev} 
                onChange={e => setMinSev(e.target.value)}
                min="1"
                max="10"
              />
            </div>
            
            <div className="form-group">
              <label>Claim Timeout (days, 1-30):</label>
              <input 
                type="number" 
                value={claimTimeout} 
                onChange={e => setClaimTimeout(e.target.value)}
                min="1"
                max="30"
              />
            </div>
            
            <button 
              onClick={postBounty} 
              disabled={loading}
              className="btn-primary btn-large"
            >
              {loading ? 'Posting...' : 'Post Bounty'}
            </button>
          </div>
        )}
      </main>
      
      <footer>
        <p>Built with ❤️ by eGold | Powered by ZK-SNARKs</p>
        <p>Contract: {formatAddr(BOUNTY_ESCROW)}</p>
      </footer>
    </div>
  )
}

export default App
